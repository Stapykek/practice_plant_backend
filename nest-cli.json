      "root": "apps/plant-type-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/plant-type-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/plant-type-microservice/tsconfig.app.json"
      }
    },
    "types": {
      "type": "library",
      "root": "libs/types",
      "entryFile": "index",
      "sourceRoot": "libs/types/src",
      "compilerOptions": {
        "tsConfigPath": "libs/types/tsconfig.lib.json"
      }
    },
    "user-microservice": {
      "type": "application",
