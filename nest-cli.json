{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/practice_plant_backend/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/practice_plant_backend/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/practice_plant_backend",
  "projects": {
    "auth-microservice": {
      "type": "application",
      "root": "apps/auth-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/auth-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-microservice/tsconfig.app.json"
      }
    },
    "constants": {
      "type": "library",
      "root": "libs/constants",
      "entryFile": "index",
      "sourceRoot": "libs/constants/src",
      "compilerOptions": {
        "tsConfigPath": "libs/constants/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "disease-microservice": {
      "type": "application",
      "root": "apps/disease-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/disease-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/disease-microservice/tsconfig.app.json"
      }
    },
    "disease-tag-microservice": {
      "type": "application",
      "root": "apps/disease-tag-microservice",
      "entryFile": "main",
      "sourceRoot": "apps/disease-tag-microservice/src",
      "compilerOptions": {
        "tsConfigPath": "apps/disease-tag-microservice/tsconfig.app.json"
      }
    },
    "entities": {
      "type": "library",
      "root": "libs/entities",
      "entryFile": "index",
      "sourceRoot": "libs/entities/src",
      "compilerOptions": {
        "tsConfigPath": "libs/entities/tsconfig.lib.json"
      }
    },
    "errors": {
      "type": "library",
      "root": "libs/errors",
      "entryFile": "index",
      "sourceRoot": "libs/errors/src",
      "compilerOptions": {
        "tsConfigPath": "libs/errors/tsconfig.lib.json"
      }
    },
    "gate": {
      "type": "application",
      "root": "apps/gate",
      "entryFile": "main",
      "sourceRoot": "apps/gate/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gate/tsconfig.app.json"
      }
